# Django
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=generate-a-real-key-with-python-secrets
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0,api.auditsence.leadrisks.com,161.97.101.121

# PostgreSQL (used when DB_HOST is set, e.g. in Docker)
POSTGRES_DB=iams_db
POSTGRES_USER=iams_user
POSTGRES_PASSWORD=iams_password

# Database connection (backend reads these when running in Docker)
DB_HOST=db
DB_PORT=5432
DB_NAME=iams_db
DB_USER=iams_user
DB_PASSWORD=iams_password

CORS_ALLOWED_ORIGINS=https://auditsence.leadrisks.com,https://auditsence.netlify.app,https://sigma17.vercel.app
CSRF_TRUSTED_ORIGINS=https://api.auditsence.leadrisks.com

# Super Admin seed (used by: manage.py seed_rbac)
SUPER_ADMIN_EMAIL=admin@company.com
SUPER_ADMIN_PASSWORD=change-me-in-production
