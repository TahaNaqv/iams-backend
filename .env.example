# ─────────────────────────────────────────────────────────────────────
# IAMS backend environment template
#
# Copy to `.env` and fill in real values. Never commit .env to git.
# Production deployments should source secrets from HashiCorp Vault,
# Docker secrets, or the platform's secret manager — not a flat file.
# ─────────────────────────────────────────────────────────────────────

# Which settings module to load. Choices:
#   config.settings.dev   — local development (default)
#   config.settings.prod  — production
#   config.settings.test  — automated tests (rarely set explicitly)
DJANGO_SETTINGS_MODULE=config.settings.dev

# ── Core security ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=generate-a-real-key-with-python-secrets
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0
LOG_LEVEL=INFO
TIME_ZONE=UTC

# ── CORS / CSRF ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ─────────────────────────────────────────────────────────
# Either provide DATABASE_URL (preferred — django-environ parses it)
DATABASE_URL=postgres://iams_user:iams_secret@db:5432/iams_db
DB_CONN_MAX_AGE=60

# Legacy split-var fallback (still consumed by docker-compose for postgres init)
POSTGRES_DB=iams_db
POSTGRES_USER=iams_user
POSTGRES_PASSWORD=iams_secret

# ── Redis (cache + Celery broker) ────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── JWT lifetimes ────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# ── Object storage (MinIO locally, S3-compatible cluster in prod) ────
# Set USE_S3_STORAGE=1 in dev to point Django at MinIO instead of local disk.
USE_S3_STORAGE=0
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=iams-evidence
S3_REGION=us-east-1
S3_USE_SSL=0
S3_ADDRESSING_STYLE=path
S3_SIGNED_URL_EXPIRY=900

# MinIO root credentials (used by the minio service in docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Email ────────────────────────────────────────────────────────────
# Dev: mailhog (no auth, no TLS, port 1025, web UI at :8025)
# Prod: corporate SMTP relay or Postfix on-host
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=0
DEFAULT_FROM_EMAIL=iams-noreply@iams.local

# ── Super admin seed (used by: manage.py seed_rbac) ──────────────────
SUPER_ADMIN_EMAIL=admin@iams.local
SUPER_ADMIN_PASSWORD=change-me-in-production

# ── Observability (production only) ──────────────────────────────────
# Sentry (self-hosted)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# ── OIDC / SSO (Phase 6 — Keycloak) ──────────────────────────────────
OIDC_RP_CLIENT_ID=
OIDC_RP_CLIENT_SECRET=
OIDC_OP_AUTHORIZATION_ENDPOINT=
OIDC_OP_TOKEN_ENDPOINT=
OIDC_OP_USER_ENDPOINT=
OIDC_OP_JWKS_ENDPOINT=

# ── HashiCorp Vault (production only) ────────────────────────────────
VAULT_ADDR=
VAULT_TOKEN=
VAULT_NAMESPACE=

# ── Gunicorn tuning (production) ─────────────────────────────────────
GUNICORN_WORKERS=
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

# ── Feature flags ────────────────────────────────────────────────────
ENABLE_DEBUG_TOOLBAR=0
