<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Audit Summary — Q1 Treasury</title>
  <style>
    @page { size: A4; margin: 18mm 16mm 22mm 16mm;
      @bottom-center { content: "Page " counter(page) " of " counter(pages); font-size: 9pt; color: #6b7280; }
    }
    body { font-family: -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; color: #0f172a; font-size: 10pt; line-height: 1.4; margin: 0; }
    h1 { font-size: 20pt; margin: 0 0 4pt; }
    h2 { font-size: 14pt; border-bottom: 1px solid #e5e7eb; padding-bottom: 4pt; margin-top: 18pt; }
    h3 { font-size: 11pt; color: #334155; margin: 12pt 0 6pt; }
    .meta { color: #64748b; font-size: 9pt; margin-bottom: 16pt; }
    .kpis { display: flex; gap: 8pt; margin: 8pt 0; }
    .kpi { flex: 1; border: 1px solid #e5e7eb; border-radius: 4pt; padding: 8pt; text-align: center; }
    .kpi .label { font-size: 9pt; color: #6b7280; }
    .kpi .value { font-size: 18pt; font-weight: 700; }
    table { width: 100%; border-collapse: collapse; margin: 8pt 0; }
    th, td { text-align: left; padding: 4pt 6pt; border-bottom: 1px solid #e5e7eb; font-size: 9pt; }
    th { background: #f8fafc; color: #475569; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; font-size: 8pt; }
    .pill { display: inline-block; padding: 1pt 6pt; border-radius: 10pt; font-size: 8pt; font-weight: 600; }
    .pill.critical { background: #fee2e2; color: #991b1b; }
    .pill.high     { background: #fed7aa; color: #9a3412; }
    .pill.medium   { background: #fef3c7; color: #854d0e; }
    .pill.low      { background: #dcfce7; color: #14532d; }
    .pill.open, .pill.in_progress { background: #dbeafe; color: #1e40af; }
    .pill.overdue, .pill.rejected { background: #fee2e2; color: #991b1b; }
    .pill.closed, .pill.approved  { background: #dcfce7; color: #14532d; }
    .footer { margin-top: 24pt; font-size: 8pt; color: #6b7280; }
  </style>
</head>
<body>
  <header>
    <h1>Audit Summary — Q1 Treasury</h1>
    <p class="meta">IAMS · Internal Audit Management System</p>
  </header>
  
  <h2>Engagement Overview</h2>
  <table>
    <tr><th>Department</th><td>Finance</td>
        <th>Lead Auditor</th><td>L</td></tr>
    <tr><th>Status</th><td>In Progress</td>
        <th>Priority</th><td>High</td></tr>
    <tr><th>Risk Rating</th><td>High</td>
        <th>Completion</th><td>60%</td></tr>
    <tr><th>Start</th><td>Jan. 1, 2026</td>
        <th>End</th><td>March 31, 2026</td></tr>
    <tr><th>Scope</th><td colspan="3">Treasury operations</td></tr>
    <tr><th>Objectives</th><td colspan="3">Validate controls</td></tr>
  </table>

  <h2>Findings by Severity</h2>
  <div class="kpis">
    
    <div class="kpi"><div class="label">Critical</div><div class="value">1</div></div>
    <div class="kpi"><div class="label">High</div><div class="value">0</div></div>
    <div class="kpi"><div class="label">Medium</div><div class="value">1</div></div>
    <div class="kpi"><div class="label">Low</div><div class="value">0</div></div>
  </div>

  <h2>Findings (2)</h2>
  
  <table>
    <thead><tr><th>Title</th><th>Severity</th><th>Status</th><th>Owner</th><th>Due</th></tr></thead>
    <tbody>
    
      <tr>
        <td>Recon timing</td>
        <td><span class="pill medium">Medium</span></td>
        <td><span class="pill inprogress">In Progress</span></td>
        <td>o@iams.test</td>
        <td>May 1, 2026</td>
      </tr>
    
      <tr>
        <td>Wire SoD gap</td>
        <td><span class="pill critical">Critical</span></td>
        <td><span class="pill open">Open</span></td>
        <td>o@iams.test</td>
        <td>April 15, 2026</td>
      </tr>
    
    </tbody>
  </table>
  

  <h2>Corrective Action Plans (0)</h2>
  <div class="kpis">
    <div class="kpi"><div class="label">Open</div><div class="value">0</div></div>
    <div class="kpi"><div class="label">In Progress</div><div class="value">0</div></div>
    <div class="kpi"><div class="label">Overdue</div><div class="value">0</div></div>
    <div class="kpi"><div class="label">Closed</div><div class="value">0</div></div>
  </div>
  

  <p class="footer">Generated by IAMS. This document may contain confidential information.</p>
</body>
</html>
