# Django
SECRET_KEY=your-django-secret-key-change-in-production
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0

# PostgreSQL (used when DB_HOST is set, e.g. in Docker)
POSTGRES_DB=iams_db
POSTGRES_USER=iams_user
POSTGRES_PASSWORD=iams_secret

# Database connection (backend reads these when running in Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iams_db
DB_USER=iams_user
DB_PASSWORD=iams_secret
